# Required: Slack Bot Token (xoxb-*)
# Get from: https://api.slack.com/apps > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Required (Phase 2): Slack App-Level Token (xapp-*)
# Get from: https://api.slack.com/apps > Basic Information > App-Level Tokens
# Scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-token

# Required: Default Slack channel ID for notifications
# Find: Right-click channel name > View channel details > scroll to bottom
SLACK_DEFAULT_CHANNEL_ID=C07ABC123

# Optional: Comma-separated authorized user IDs for inbound reply injection (Phase 2)
# Find: Click user profile > More > Copy member ID
SLACK_AUTHORIZED_USER_IDS=U0DEVELOPER

# Optional: Default mention prefix for notifications
SLACK_MENTION=<@U0DEVELOPER>

# Optional: Custom session registry path (default: ~/.omc/state/slack-session-registry.jsonl)
# SLACK_REGISTRY_PATH=~/.omc/state/slack-session-registry.jsonl

# Optional: Default timeout for slack_ask in seconds (default: 120)
# SLACK_ASK_TIMEOUT=120
